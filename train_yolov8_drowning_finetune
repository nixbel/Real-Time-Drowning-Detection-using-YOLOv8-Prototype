#!/bin/bash
# fine_tune_yolo_drowning_finetune.sh

# ==========================
# GPU & Environment
# ==========================
export CUDA_VISIBLE_DEVICES=1
source ~/anaconda3/etc/profile.d/conda.sh
conda activate yolov8detection

# ==========================
# Paths
# ==========================
DATA_PATH="/data.yaml"
BASE_MODEL="/weights/best.pt"
PROJECT_DIR="/runs/detect"

# ==========================
# Training
# ==========================
yolo detect train \
    data="$DATA_PATH" \
    model="$BASE_MODEL" \
    project="$PROJECT_DIR" \
    epochs=150 \
    imgsz=640 \
    batch=16 \
    device=1 \
    lr0=0.001 \
    lrf=0.01 \
    momentum=0.937 \
    weight_decay=0.0005 \
    warmup_epochs=3 \
    optimizer=AdamW \
    hsv_h=0.015 \
    hsv_s=0.7 \
    hsv_v=0.4 \
    degrees=5.0 \
    translate=0.05 \
    scale=0.8 \
    shear=0.1 \
    flipud=0.0 \
    fliplr=0.5 \
    mosaic=0.7 \
    mixup=0.1 \
    cache=True \
    patience=20 \
    close_mosaic=10 \
    label_smoothing=0.05 \
    pretrained=True \
    save_period=10
